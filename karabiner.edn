;; ╔══════════════════════════════════════════════════════════════════════════╗
;; ║  Karabiner config (GokuRakuJoudo / goku)                                   ║
;; ║  Modifier legend & <other options> reference: see bottom of file.          ║
;; ╚══════════════════════════════════════════════════════════════════════════╝

{;; ─────────────────────────────── Profiles ───────────────────────────────────
 :profiles {:Default {:default true   ;; rules land here when no profile is specified
                      :sim     50      ;; simultaneous_threshold_milliseconds (simlayers)
                      :delay   500     ;; to_delayed_action_delay_milliseconds
                      :alone   1000    ;; to_if_alone timeout
                      :held    500}}   ;; to_if_held_down threshold

 ;; ───────────────────────────── Applications ─────────────────────────────────
 ;; Get a bundle id with:  mdls -name kMDItemCFBundleIdentifier /Applications/App.app
 :applications {:safari    ["^com\\.apple\\.Safari$"]
                :chrome    ["^com\\.google\\.Chrome$"]
                :finder    ["^com\\.apple\\.finder$"]
                :obsidian  ["^md\\.obsidian$"]
                :notion    ["^notion\\.id$"]
                :music     ["^com\\.apple\\.Music"]
                :code      ["^com\\.visualstudio\\.code\\.oss$"
                            "^com\\.microsoft\\.VSCode(Insiders)?$"
                            "^com\\.microsoft\\.VSCode?$"
                            "com\\.exafunction\\.windsurf"
                            "com.google.antigravity"
                            "com.todesktop.230313mzl4w4u92"]
                :terminals ["^com\\.apple\\.Terminal$"
                            "^com\\.googlecode\\.iterm2$"]
                :warp      ["^dev\\.warp\\.Warp-Stable$"]
                :mail      ["^com\\.apple\\.mail$"]
                :notes     ["^com\\.apple\\.Notes$"]
                :calendar  ["^com\\.apple\\.iCal$"]
                :preview1  ["^com\\.apple\\.Preview$" :previewsidebar]
                :preview0  ["^com\\.apple\\.Preview$" :!previewsidebar]
                :terminal  ["^com\\.apple\\.Terminal$"]
                :chatgpt   ["^com\\.openai\\.ChatGPT$"]
                :postman   ["^com\\.postmanlabs\\.mac$"]
                :intellij  ["^com\\.jetbrains.intellij\\.ce$"]
                :anki      ["^net\\.ankiweb\\.launcher"]
                :windowsapp ["^com\\.microsoft\\.rdc\\.macos$"]}

 ;; ─────────────────────────────── Templates ──────────────────────────────────
 :templates {:yabai      "/opt/homebrew/bin/yabai -m %s"
             :launch-app "open -a '%s'"
             :close-app  "osascript -e 'quit app \"%s\"'"
             :open       "open -n '/Applications/%s.app'"
             :directory  "open ~/%s"}

 ;; ──────────────────────────────── Devices ───────────────────────────────────
 :devices {:g305-device       [{:vendor_id 1133 :product_id 50495}]
           :internal-keyboard [{:vendor_id 1452 :product_id 835}]}

 ;; ──────────────────────────────── Layers ────────────────────────────────────
 :layers {:hyper-mode  {:key :caps_lock :alone {:key :return_or_enter}}
          :launch-mode {:key :slash :condi :!anki}
          :mouse-mode4 {:key :keypad_4 :condi :g305-device :alone {:key :!Tup_arrow}}}

 ;; ─────────────────────────────── Simlayers ──────────────────────────────────
 :simlayers {:tmux-winmove-mode {:key :q :condi :Terminals}
             :period-mode       {:key :period}
             :comma-mode        {:key :comma}
             :z-mode            {:key :z}
             :x-mode            {:key :x}
             :c-mode            {:key :c}}

 :main
 [;; ═══════════════════════════ Modifiers & basics ═══════════════════════════
  {:des "Capslock to Hyper, Return if alone"
   :rules [[:##caps_lock :fn nil {:alone :return_or_enter}]]}

  {:des "Command to option, option to Command"
   :rules [;; [:##left_command :##left_option]
           ;; [:##left_option :##left_command]
           [:!Cm []]
           [:!Ch []]]}

  {:des "Toggle caps_lock by pressing left_shift then right_shift"
   :rules [[:!S#Pright_shift :caps_lock]
           [:!R#Pleft_shift :caps_lock]]}

  {:des "Function to ESC"
   :rules [[:fn :escape nil {:held :fn :params {:held 100}}]]}

  {:des "Shift deletes Forward and Backward"
   :rules [[:#Pright_shift :right_shift nil {:alone :!OFdelete_or_backspace}]
           [:#Pleft_shift :left_shift nil {:alone :!Odelete_or_backspace}]]}

  {:des "Directional Keys"
   :rules [[:!F##j :up_arrow]
           [:!F##k :left_arrow]
           [:!F##l :right_arrow]
           [:!F##semicolon :down_arrow]]}

  ;; ════════════════════════════════ Anki ════════════════════════════════════
  {:des "Toggle Anki"
   :rules [[[:right_control {:pkey :button2}] [:yabai "window --toggle anki || open -a Anki"]]
           [:open_bracket [:yabai "window --toggle anki || open -a Anki"] :anki-layer]
           ;; [:hyphen :hyphen :!anki-layer {:held ["anki-layer" 1] :params {:held 500}}]
           [[:hyphen :equal_sign] ["anki-layer" 1] :!anki-layer]
           [[:hyphen :equal_sign] ["anki-layer" 0] :anki-layer]]}

  {:des "Anki controls"
   :rules [:anki
           ;; ── layer toggle ──
           [[:right_control :right_command] ["anki-layer" 1] :!anki-layer]
           [[:right_control :right_command] ["anki-layer" 0] :anki-layer]
           [:!REQa ["anki-layer" 1] :!anki-layer]
           [:!REQa ["anki-layer" 0] :anki-layer]
           ;; ── mouse / playback ──
           [[{:pkey :button1} {:pkey :button2}] [{:pkey :button1} {:pkey :button1} {:pkey :button1} :!CTOt]]
           [[:right_command {:pkey :button1}] :rewind]
           [[:right_command {:pkey :button2}] :fast_forward]
           [[:right_control {:pkey :button1}] :play_or_pause]
           [:right_command :!SCz :anki-layer]
           [:right_control :!Cz :anki-layer]
           [:right_command :volume_decrement]
           [:right_control :volume_increment]
           [{:pkey :button1} :return_or_enter :anki-layer]
           [{:pkey :button2} :semicolon :anki-layer]
           ;; ── inf (definition) toggle ──
           [:#Pquote [:i ["inf" 1]] [:anki-layer :!inf]]
           [:#Pquote [:escape ["inf" 0]] [:anki-layer :inf]]
           ;; ── stats toggle ──
           [:close_bracket [:t ["stats" 1]] [:anki-layer :!stats]]
           [:close_bracket [:escape ["stats" 0]] [:anki-layer :stats]]
           ;; ── scroll while stats OR inf is active (separate manipulators = OR) ──
           [:hyphen {:mkey {:vwheel -40 :speed 2}} [:stats]]
           [:hyphen {:mkey {:vwheel -40 :speed 2}} [:inf]]
           [:equal_sign {:mkey {:vwheel 40 :speed 2}} [:stats]]
           [:equal_sign {:mkey {:vwheel 40 :speed 2}} [:inf]]
           ;; ── misc ──
           [:#Pslash :r :anki-layer]
           [:backslash :escape :anki-layer]
           [:comma :!C#Pz :anki-layer]
           [:period :!SC#Pz :anki-layer]]}

  ;; ════════════════════════════════ Yabai ═══════════════════════════════════
  {:des "Mouse mode"
   :rules [:g305-device
           [:right_command :right_command :!anki {:alone :!C#Pclose_bracket}]
           [:right_control :right_control :!anki {:alone :!C#Popen_bracket}]
           [:keypad_3 :!C#Ptab]]}

  {:des "Yabai keybinds"
   :rules [;; ─────────────── Navigation: focus spaces (SIP deactivated) ───────────────
           ;; SIP-activated variants (display --focus) kept for reference:
           ;; [:!E#Pz [:!Ez [:yabai "display --focus 1"]]] ... etc.
           [:!E#Pz [:yabai "space --focus 5"] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!E#Px [:yabai "space --focus 6"] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!E#Pc [:yabai "space --focus 7"] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!E#Pv [:yabai "space --focus 8"] nil {:afterup [:yabai "window --focus mouse"]}]

           [:!O#Pm [:yabai "space --focus 1 "] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!O#Pcomma [:yabai "space --focus 2"] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!O#Pperiod [:yabai "space --focus 3"] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!O#Pslash [:yabai "space --focus 4"] nil {:afterup [:yabai "window --focus mouse"]}]

           [:!E#Pb [:yabai "space --focus 9"] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!O#Pn [:yabai "space --focus 10"] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!O#Pi [:yabai "space --focus 11"] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!O#Po [:yabai "space --focus 12"] nil {:afterup [:yabai "window --focus mouse"]}]

           ;; ─────────────── Navigation: focus windows ───────────────
           [:!O#Psemicolon [:yabai "window --focus stack.next"]]
           [:!O#Pj [:yabai "window --focus stack.prev"]]
           [:!O#Pk [:yabai "window --focus west"]]
           [:!O#Pl [:yabai "window --focus east"]]
           [:!O#Pf [:yabai "window --focus stack.recent"]]
           [:!E#Pf [:yabai "window --focus stack.recent"]]

           ;; ─────────────── Navigation: focus displays ───────────────
           [:!O#Pu [:yabai "display --focus recent"]]

           ;; ─────────────── Modify: move window relatively (warp) ───────────────
           [:!TO#Psemicolon [:yabai "window --warp south"]]
           [:!TO#Pj [:yabai "window --warp north"]]
           [:!TO#Pk [:yabai "window --warp west"]]
           [:!TO#Pl [:yabai "window --warp east"]]

           [:!FT#Psemicolon [:yabai "window --stack next"]]
           [:!FT#Pj [:yabai "window --stack prev"]]

           ;; ─────────────── Modify: swap windows ───────────────
           [:!SO#Psemicolon [:yabai "window --swap south"]]
           [:!SO#Pj [:yabai "window --swap north"]]
           [:!SO#Pk [:yabai "window --swap west"]]
           [:!SO#Pl [:yabai "window --swap east"]]

           ;; ─────────────── Modify: send window to space ───────────────
           [:!FO#Pm [:yabai "window --space 1"]]
           [:!FO#Pcomma [:yabai "window --space 2"]]
           [:!FO#Pperiod [:yabai "window --space 3"]]
           [:!FO#Pslash [:yabai "window --space 4"]]

           [:!FO#Pz [:yabai "window --space 5"]]
           [:!FO#Px [:yabai "window --space 6"]]
           [:!FO#Pc [:yabai "window --space 7"]]
           [:!FO#Pv [:yabai "window --space 8"]]

           [:!FE#Pz [:yabai "window --space 5"]]
           [:!FE#Px [:yabai "window --space 6"]]
           [:!FE#Pc [:yabai "window --space 7"]]
           [:!FE#Pv [:yabai "window --space 8"]]

           [:!FO#Pb [:yabai "window --space 9"]]
           [:!FO#Pn [:yabai "window --space 10"]]
           [:!FO#Pi [:yabai "window --space 11"]]
           [:!FO#Po [:yabai "window --space 12"]]

           ;; ─────────────── App scratchpads (toggle or open) ───────────────
           [:!F#Pr [:yabai "window --toggle redis || open -a 'Another Redis Desktop Manager'"]]
           [:!F#Pf [:yabai "window --toggle finder || open -a Finder"]]
           [:!F#Pw [:yabai "window --toggle musica || open -a Music"]]
           [:!F#Pq [:yabai "window --toggle whatsapp || open -a WhatsApp"]]
           [:!FC#Pq [:yabai "window --toggle slack || open -a Slack"]]
           [:!F#Pd [:yabai "window --toggle warp || open -a Warp"]]
           [:!F#Pc [:yabai "window --toggle gpt || open -a ChatGPT"]]
           [:!F#Pg [:yabai "window --toggle gatherv2 || open -a GatherV2"]]
           [:!F#Pe [:yabai "window --toggle mail || open -a Mail"]]
           [:!F#Pa [:yabai "window --toggle anki || open -a Anki"] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!F#Pv [:yabai "window --toggle obsidian || open -a Obsidian"]]
           [:!F#Py [:yabai "window --toggle simulator || open -a Simulator"]]

           ;; ─────────────── Window state ───────────────
           [:!F#Ps [:yabai "window --toggle sticky"]]
           [:!F#Pz [:yabai "window --raise"]]
           [:!F#Px [:yabai "window --minimize"]]

           ;; ─────────────── Set insertion point in focused container ───────────────
           [:!E#Ps [:yabai "window --insert stack"]]
           [:!E#Pw [:yabai "window --insert east"]]

           ;; ─────────────── Equalize / balance ───────────────
           [:!FC#Pe [:yabai "space --balance"]]
           [:!FC#Px [:yabai "space --equalize x-axis"]]
           [:!FC#Py [:yabai "space --equalize y-axis"]]

           ;; ─────────────── Rotate / mirror ───────────────
           [:!FO#Pr [:yabai "space --rotate 270"]]
           [:!FO#Px [:yabai "space --mirror x-axis"]]
           [:!FO#Py [:yabai "space --mirror y-axis"]]

           ;; ─────────────── Float / fullscreen / zoom ───────────────
           [:!FO#Pspacebar [:yabai "window --toggle float --grid 11:11:1:1:7:7"]]
           [:!T#Pf [:yabai "window --toggle zoom-parent"]]
           [:!O#Pa [:yabai "window --toggle zoom-fullscreen"]]
           [:!E#Pa [:yabai "window --toggle zoom-fullscreen"]]

           ;; ─────────────── Start / stop yabai service ───────────────
           [:!TOC#Pr "pkill yabai"]
           ;; [:!TOC#Pp "yabai --restart-service"]
           [:!TOC#Pp "yabai --stop-service"]
           [:!TOC#Ps "yabai --start-service"]

           ;; ─────────────── Resize window ───────────────
           [:!FC#Pm [:yabai "window --resize bottom:0:-100 2> /dev/null|| /opt/homebrew/bin/yabai window --resize top:0:-100 2> /dev/null"]]
           [:!FC#Pcomma [:yabai "window --resize right:-100:0 2> /dev/null || /opt/homebrew/bin/yabai window --resize left:-100:0 2> /dev/null"]]
           [:!FC#Pperiod [:yabai "window --resize right:100:0 2> /dev/null|| /opt/homebrew/bin/yabai window --resize left:100:0 2> /dev/null"]]
           [:!FC#Pslash [:yabai "window --resize bottom:0:100 2> /dev/null || /opt/homebrew/bin/yabai window --resize top:0:100 2> /dev/"]]

           ;; ─────────────── Move window (rel) ───────────────
           [:!FC#Pu [:yabai "window --move rel:0:-150"]]
           [:!FC#Pi [:yabai "window --move rel:-200:0"]]
           [:!FC#Po [:yabai "window --move rel:200:0"]]
           [:!FC#Pp [:yabai "window --move rel:0:150"]]]}

  ;; g305 mouse buttons map:  Q right_command | W right_control | E right_option
  ;;                          R right_shift   | P caps_lock
  {:des "Mouse navigation"
   :rules [;; use :condi as first element for multiple conditions, e.g. [:condi :g305-device :f1-mode]
           ;; ── W: focus + send to spaces 4..1 / 10..12 ──
           [:!Wz [:yabai "space --focus 4 "] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!Wx [:yabai "space --focus 3 "] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!Wc [:yabai "space --focus 2 "] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!Wv [:yabai "space --focus 1 "] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!Wz [:yabai "window --space 4"]]
           [:!Wx [:yabai "window --space 3"]]
           [:!Wc [:yabai "window --space 2"]]
           [:!Wv [:yabai "window --space 1"]]
           ;; ── Q: focus + send to spaces 8..5 ──
           [:!Qz [:yabai "space --focus 8 "] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!Qx [:yabai "space --focus 7 "] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!Qc [:yabai "space --focus 6 "] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!Qv [:yabai "space --focus 5 "] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!Qz [:yabai "window --space 8"]]
           [:!Qx [:yabai "window --space 7"]]
           [:!Qc [:yabai "window --space 6"]]
           [:!Qv [:yabai "window --space 5"]]
           ;; ── W: spaces 10/11/12 ──
           [:!Wb [:yabai "space --focus 10 "] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!WSb [:yabai "window --space 10"]]
           [:!Ww [:yabai "space --focus 11 "] nil {:afterup [:yabai "window --focus mouse"]}]
           [:!WSw [:yabai "window --space 11"]]
           [:!We [:yabai "space --focus 12 "] nil {:afterup [:yabai "window --focus mouse"]}]
           ;; ── W: focus windows / zoom ──
           [:!Ws [:yabai "window --focus west"]]
           [:!Wd [:yabai "window --focus east"]]
           [:!Wf [:yabai "window --focus stack.recent"]]
           [:!Wa [:yabai "window --toggle zoom-fullscreen"]]
           ;; ── Q: tab navigation ──
           [:!Qw :!SCopen_bracket]
           [:!Qe :!SCclose_bracket]
           [:!Qq :!Tu [:code]]
           [:!Qr :!CTOp [:code]]
           ;; ── space prev/next (mouse-mode4) ──
           [:s [:yabai "space --focus prev"] :mouse-mode4]
           [:d [:yabai "space --focus next"] :mouse-mode4]]}

  ;; ════════════════════════════ Media / system ══════════════════════════════
  {:des "Media control"
   :rules [[:!F#Pm :play_or_pause]
           [:!F#Pcomma :rewind]
           [:!F#Pperiod :fast_forward]
           [:#Pv :play_or_pause :mouse-mode4]
           [:#Px :rewind :mouse-mode4]
           [:#Pc :fast_forward :mouse-mode4]]}

  {:des "Volume control"
   :rules [[:comma :volume_decrement :x-mode]
           [:period :volume_increment :x-mode]
           [:w :volume_decrement :mouse-mode4]
           [:e :volume_increment :mouse-mode4]]}

  {:des "Brightness control"
   :rules [[:comma :display_brightness_decrement :z-mode]
           [:period :display_brightness_increment :z-mode]
           [:#Pcomma :illumination_decrement :c-mode]
           [:#Pperiod :illumination_increment :c-mode]
           [:#Pq :display_brightness_decrement :mouse-mode4]
           [:#Pr :display_brightness_increment :mouse-mode4]]}

  {:des "Scroll control"
   :rules [[:!F#CP9 {:mkey {:vwheel 30 :speed 2}}]
           [:!F#CP8 {:mkey {:vwheel -30 :speed 2}}]
           ;; [:!O#CP9 {:mkey {:hwheel -20 :speed 2}}]
           ;; [:!O#CP8 {:mkey {:hwheel 20 :speed 2}}]
           ]}

  ;; ══════════════════════════ App-specific bindings ═════════════════════════
  {:des "Clean Keyboard mode"
   :rules [[:#Pc [["clean-mode" 1] [:launch-app "KeyboardCleanTool"]] [:launch-mode :!clean-mode]]
           [:#Pc [["clean-mode" 0] [:close-app "KeyboardCleanTool"]] [:launch-mode :clean-mode]]]}

  {:des "Navigation Tabs"
   :rules [[:!F#Pi :!SCopen_bracket]
           [:!F#Po :!SCclose_bracket]]}

  {:des "Next, Prev Cursor VsCode"
   :rules [:code
           [:!F#Pu :!Tu]
           [:!F#Pp :!CTOp]
           [:!F#Pn :!Ttab]
           [:!F#Pslash :!Ff12]]}

  {:des "Next, Prev Cursor intellij"
   :rules [[:!F#Pu :!Thyphen :intellij]
           [:!F#Pp :!SThyphen :intellij]]}

  {:des "ShortCat"
   :rules [[:!F#Ph :!COTspacebar]]}

  {:des "DeepL"
   :rules [;; [:!F#Pt :!CTOt nil {:delayed {:invoked [:!Ctab :fn] :canceled []} :params {:delay 200}}]
           [:!F#Pt :!CTOt]
           [{:pkey :button13} [{:pkey :button1} {:pkey :button1} :!CTOt]]]}

  {:des "Opening Apps"
   :rules [:launch-mode
           [:#Pm [:launch-app "music"]]
           [:#Pw [:launch-app "WhatsApp"]]
           [:#Pn [:launch-app "Notion"]]
           [:#Py [:launch-app "System Preferences"]]
           [:#Pi [:launch-app "IntelliJ IDEA CE"]]
           [:#Pg [:launch-app "Google Chrome"]]
           [:#Ps [:launch-app "Safari"]]
           [:#Pb [:launch-app "Dbeaver"]]
           [:#Pe [:launch-app "Insomnia"]]
           [:#Pd [:directory "Downloads"]]
           [:!S#Pd [:directory "Desktop"]]
           [:#Pr [:directory ""]]]}

  {:des "Comma Mode [,] as Trigger Key"
   :rules [:comma-mode
           [:a :open_bracket]
           [:s :close_bracket]
           [:d :!S7]
           [:f :!S8]
           [:q :!Shyphen]
           [:w :!Sequal_sign]
           [:e :!S5]
           [:r :!S6]]}

  {:des "Period Mode [.] as Trigger Key"
   :rules [:period-mode
           [:comma ["period-comma-mode" 1] nil {:alone :comma :afterup ["period-comma-mode" 0]}]
           [:a [:!Sgrave_accent_and_tilde :slash]]
           [:s [:period :!S8]]
           [:d :!S9]
           [:f :!S0]
           [:q :hyphen]
           [:w :equal_sign]
           [:e :!Sopen_bracket]
           [:r :!Sclose_bracket]]}

  {:des "HYPER: Hyper+B = Universal sidebar toggle"
   :rules [[:!F#Pb [:!C#Pbackslash] :postman]
           [:!F#Pb [:!OCs] :notes]
           [:!F#Pb [:!SCl] :safari]
           [:!F#Pb [:!COb] :chrome]              ;; shows bookmark manager
           [:!F#Pb [:!Cb] :code]                 ;; covers VSCode + Windsurf (same bundle group)
           [:!F#Pb [:!CTs] :finder]
           [:!F#Pb [:!Cbackslash] :notion]
           [:!F#Pb [:!SCl] :obsidian]
           [:!F#Pv [:!CTs] :obsidian]
           [:!F#Pb [:!CTs] :mail]
           [:!F#Pb [:!CO2 ["previewsidebar" 0]] :preview1]
           [:!F#Pb [:!CO1 ["previewsidebar" 1]] :preview0]
           [:!F#Pb [:!CSbackslash] :terminal]    ;; no sidebar, so tab overview instead
           [:!F#Pb [:!CTs]]]}                     ;; default: cmd-ctrl-s in any other app
  ]}

